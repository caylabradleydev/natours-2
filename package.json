{
  "name": "natours",
  "version": "1.0.0",
  "description": "Landing Page for Natours",
  "homepage": "https://github.com/caylabradleydev/natours-2#readme",
  "bugs": {
    "url": "https://github.com/caylabradleydev/natours-2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caylabradleydev/natours-2.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "watch:sass": "sass --watch sass/main.scss css/style.css",
    "devserver": "live-server",
    "start": "npm-run-all --parallel watch:sass devserver",

    
    "compile:sass": "sass sass/main.scss css/style.comp.css",
    "concat:css": "concat -o css/style.concat.css css/fonts/icon-font.css css/style.comp.css",
    "prefix:css": "postcss --use autoprefixer -b 'last 10 versions' css/style.concat.css -o css/style.prefix.css",
    "compress:css": "sass --style=compressed css/style.prefix.css css/style.css",
    "build:css": "npm-run-all compile:sass concat:css prefix:css compress:css"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concat": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.1",
    "sass": "^1.97.3"
  }
}
